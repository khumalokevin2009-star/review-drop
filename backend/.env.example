# App
APP_NAME=Orvelle
APP_ENV=development                  # development | staging | production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Database
# Note: the `reviewdrop` database name is legacy by design — kept on the rebrand
# so existing local volumes and managed instances keep working.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/reviewdrop

# Auth
JWT_SECRET=<generate with: openssl rand -hex 32>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=orvelle-screenshots
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Stripe (TEST MODE only — use sk_test_/pk_test_ keys; never live keys here)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `stripe listen --forward-to localhost:8000/api/v1/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
# Pro = £19.99/mo price id (create it in the Stripe test dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# Launching with Free + Pro only — these stay unset for now:
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_STUDIO_MONTHLY_PRICE_ID=
STRIPE_STUDIO_ANNUAL_PRICE_ID=
# Days of free trial on the Pro checkout (card upfront, charged after).
STRIPE_TRIAL_PERIOD_DAYS=30

# Resend (transactional email)
RESEND_API_KEY=re_...
EMAIL_FROM="Orvelle <hello@orvellehq.com>"
EMAIL_ENABLED=true                   # set false to disable all email (dev/tests)
EMAIL_BATCH_WINDOW_MINUTES=5         # debounce window for new-comment emails

# Sentry
SENTRY_DSN=https://...

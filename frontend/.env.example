# Orvelle frontend environment variables (Vite — must be prefixed VITE_)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Stripe publishable key (TEST MODE, pk_test_...). Optional: Checkout is
# redirect-based, so the upgrade flow works without it — kept here for any
# future Stripe.js usage. Never put the secret key in the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
